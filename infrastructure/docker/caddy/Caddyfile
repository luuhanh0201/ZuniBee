{
	email {$ADMIN_EMAIL}
}

# Chuyển canonical host trước khi reverse proxy. Không thêm `http://` vào
# site address để Caddy tự cấp chứng chỉ và redirect HTTP sang HTTPS.
www.{$DOMAIN} {
	redir https://{$DOMAIN}{uri} permanent
}

# Web (Next.js)
{$DOMAIN} {
	encode gzip zstd
	header {
		-Server
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data:; connect-src 'self' https://api.{$DOMAIN}; frame-src 'self' blob:; upgrade-insecure-requests"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=()"
		X-Frame-Options "DENY"
	}
	reverse_proxy web:1112
}

# API (NestJS) — bao gồm /uploads (avatar) và /docs (Swagger)
api.{$DOMAIN} {
	encode gzip zstd
	header {
		-Server
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		Content-Security-Policy "default-src 'none'; frame-ancestors 'none'; base-uri 'none'; form-action 'none'"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "no-referrer"
		Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=()"
		X-Frame-Options "DENY"
		Cross-Origin-Resource-Policy "cross-origin"
	}
	reverse_proxy api:2223
}
