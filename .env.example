# Biến dùng cho docker-compose.yml (infra), KHÔNG phải biến của app.
# Copy file này thành .env ở root rồi điền giá trị thật trước khi `docker compose up`.
# Bí mật của app (JWT, OAuth, SMTP...) vẫn nằm trong apps/api/.env như cũ.

# Domain dùng để build URL API cho web (api.<DOMAIN>) và làm CORS origin của API.
# HTTPS + định tuyến apex->web, api.<DOMAIN>->api do ingress bên thứ ba đảm nhận.
DOMAIN=example.com

# PostgreSQL (container hoá qua docker-compose)
DATABASE_NAME=zunibee
DATABASE_USER=postgres
DATABASE_PASSWORD=

# pgAdmin — trang quản trị PostgreSQL nội bộ, publish tại 127.0.0.1:5050.
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=

# Redis (container hoá qua docker-compose)
REDIS_PASSWORD=

# Phase 2/3: encryption key for provider API keys and worker switch.
AI_PROVIDER_ENCRYPTION_KEY=
# Docker tự tạo khóa ổn định trong volume api-secrets nếu để trống.
AI_OLLAMA_ALLOWED_HOSTS=host.docker.internal
AI_OLLAMA_ALLOWED_PORTS=11434
AI_PROVIDER_PRIVATE_HOST_ALLOWLIST=
AI_DOCUMENT_PAGE_CONCURRENCY=1
AI_DOCUMENT_PDF_NATIVE_ENABLED=true
AI_DOCUMENT_PDF_BATCH_PAGES=3
AI_DOCUMENT_LOCAL_OCR_ENABLED=false
AI_GENERATION_CHUNK_ANALYSIS_CONCURRENCY=2
AI_GENERATION_CHUNK_CANDIDATE_CONCURRENCY=1
AI_GENERATION_WORKER_CONCURRENCY=1
NOTIFICATION_WORKER_ENABLED=true
