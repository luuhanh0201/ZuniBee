#
NODE_ENV=development
APP_NAME=ZuniBee API
APP_PORT=
APP_PREFIX

WEB_URL=http://localhost:1111

# Google OAuth — cần Client Secret thật để đăng nhập Google hoạt động
GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET
GOOGLE_CALLBACK_URL

# Facebook OAuth
FACEBOOK_CLIENT_ID
FACEBOOK_CLIENT_SECRET
FACEBOOK_CALLBACK_URL
FACEBOOK_GRAPH_API_VERSION

# PostgreSQL
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=zunibee
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# Redis
REDIS_HOST
REDIS_PORT
REDIS_PASSWORD

# Lưu trữ tài liệu lớp học. Production có thể ưu tiên Cloudinary và tự chuyển
# sang local khi dung lượng Cloudinary đạt ngưỡng cấu hình.
FILE_STORAGE_DRIVER=local
FILE_STORAGE_FALLBACK_DRIVER=none
CLOUDINARY_URL=
CLOUDINARY_STORAGE_PREFIX=zunibee
CLOUDINARY_STORAGE_FALLBACK_PERCENT=95
# Cache kết quả Cloudinary Admin Usage API để tránh vượt rate limit.
CLOUDINARY_USAGE_CACHE_SECONDS=60
# Có thể dùng 3 biến dưới thay CLOUDINARY_URL.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# AI provider credentials are encrypted at rest with this application key.
# Production: use a random secret of at least 32 characters and keep it stable.
AI_PROVIDER_ENCRYPTION_KEY
# Production Docker có thể dùng AI_PROVIDER_ENCRYPTION_KEY_FILE thay thế.
AI_PROVIDER_ENCRYPTION_KEY_FILE=
# Ollama local chỉ được gọi đúng host/port này. Phân tách nhiều giá trị bằng dấu phẩy.
AI_OLLAMA_ALLOWED_HOSTS=localhost,127.0.0.1,::1,host.docker.internal
AI_OLLAMA_ALLOWED_PORTS=11434
# Chỉ dùng khi chủ động cho phép provider external trỏ vào private network.
AI_PROVIDER_PRIVATE_HOST_ALLOWLIST=

# Set false when running API without the Redis notification worker.
NOTIFICATION_WORKER_ENABLED=true

# Authentication
JWT_ACCESS_SECRET
JWT_REFRESH_SECRET
JWT_ACCESS_EXPIRES_IN
JWT_REFRESH_EXPIRES_IN
AUTH_SESSION_EXPIRES_IN
AUTH_REFRESH_COOKIE_EXPIRES_IN
PASSWORD_RESET_EXPIRES_IN

# Gửi mail (quên mật khẩu) — dùng Gmail SMTP: bật xác minh 2 bước rồi tạo
# "Mật khẩu ứng dụng" tại https://myaccount.google.com/apppasswords, điền vào SMTP_USER/SMTP_PASSWORD.
SMTP_HOST
SMTP_PORT
SMTP_SECURE
SMTP_USER
SMTP_PASSWORD
MAIL_FROM
