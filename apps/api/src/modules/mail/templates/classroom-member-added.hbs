<div
  style='display:inline-block;padding:7px 12px;background-color:#dff4fd;border:2px solid #0f172a;border-radius:999px;font-size:13px;font-weight:700;'
>Đã thêm vào lớp</div>

<h1
  style='margin:22px 0 12px;font-size:28px;line-height:1.25;color:#0f172a;'
>Xin chào {{studentName}},</h1>

<p style='margin:0;color:#475569;font-size:16px;line-height:1.65;'>
  Giáo viên
  <strong style='color:#0f172a;'>{{teacherName}}</strong>
  đã thêm bạn vào lớp học dưới đây.
</p>

<table
  role='presentation'
  width='100%'
  cellspacing='0'
  cellpadding='0'
  border='0'
  style='margin:26px 0;background-color:#fff8d6;border:3px solid #0f172a;border-radius:14px;box-shadow:4px 4px 0 #0f172a;'
>
  <tr>
    <td style='padding:20px;color:#0f172a;'>
      <div
        style='font-size:12px;font-weight:700;letter-spacing:0.8px;text-transform:uppercase;color:#64748b;'
      >Lớp học</div>
      <div
        style='margin-top:7px;font-size:22px;font-weight:800;'
      >{{classroomName}}</div>
    </td>
  </tr>
</table>

<table
  role='presentation'
  width='100%'
  cellspacing='0'
  cellpadding='0'
  border='0'
>
  <tr>
    <td align='center'>
      <a
        href='{{classroomUrl}}'
        style='display:inline-block;padding:14px 24px;background-color:#2563eb;border:3px solid #0f172a;border-radius:12px;box-shadow:4px 4px 0 #0f172a;color:#ffffff;text-decoration:none;font-size:16px;font-weight:800;'
      >Mở danh sách lớp</a>
    </td>
  </tr>
</table>