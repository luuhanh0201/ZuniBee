<h1 style='margin:0 0 16px;font-size:26px;line-height:1.25;'>Cảnh báo ngân sách
  AI</h1>
<p style='margin:0 0 12px;line-height:1.6;'>Chào {{adminName}},</p>
<p style='margin:0 0 20px;line-height:1.6;'>
  Ngân sách
  <strong>{{budgetName}}</strong>
  đã đạt
  <strong>{{usageLabel}}</strong>, vượt ngưỡng cảnh báo
  <strong>{{warningLabel}}</strong>.
</p>
<table
  role='presentation'
  width='100%'
  cellspacing='0'
  cellpadding='0'
  border='0'
  style='margin:0 0 24px;border:1px solid #cbd5e1;border-radius:12px;background:#f8fafc;'
>
  <tr>
    <td style='padding:12px 16px;color:#475569;'>Phạm vi</td>
    <td
      align='right'
      style='padding:12px 16px;font-weight:700;'
    >{{scopeLabel}}</td>
  </tr>
  <tr>
    <td
      style='padding:12px 16px;border-top:1px solid #e2e8f0;color:#475569;'
    >Chu kỳ</td>
    <td
      align='right'
      style='padding:12px 16px;border-top:1px solid #e2e8f0;font-weight:700;'
    >{{periodLabel}}</td>
  </tr>
  <tr>
    <td style='padding:12px 16px;border-top:1px solid #e2e8f0;color:#475569;'>Đã
      sử dụng</td>
    <td
      align='right'
      style='padding:12px 16px;border-top:1px solid #e2e8f0;font-weight:700;'
    >{{spentLabel}} / {{limitLabel}}</td>
  </tr>
</table>
<a
  href='{{usageUrl}}'
  style='display:inline-block;border:2px solid #111827;border-radius:10px;background:#facc15;color:#111827;padding:12px 18px;font-weight:700;text-decoration:none;'
>Xem thống kê AI</a>
<p style='margin:20px 0 0;color:#64748b;font-size:13px;line-height:1.6;'>
  Email này chỉ được gửi một lần cho ngân sách trong mỗi chu kỳ ngày hoặc tháng.
</p>